# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env.local*

# local scripts — may contain sensitive derivation utilities
scripts/

# Claude Code — local dev tooling only, not needed for deployment
.claude/
CLAUDE.md
AGENTS.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
